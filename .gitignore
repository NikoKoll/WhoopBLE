# Xcode user state — machine/session specific
*.xcuserstate
xcuserdata/

# macOS
.DS_Store
**/.DS_Store

# Claude Code local settings — personal config, not shared
.claude/settings.local.json

# Swift Package Manager
.build/
*.resolved

# Editor temp files
*.swp
*.swo
